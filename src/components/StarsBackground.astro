---
---

<div id="stars"></div>
<div id="stars2"></div>
<div id="stars3"></div>
<div id="stars4"></div>
<div id="nebula"></div>
<div id="satellite"></div>

<style>
  #stars,
  #stars2,
  #stars3,
  #stars4 {
    position: fixed;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    background: transparent;
    pointer-events: none;
    z-index: 0;
    border-radius: 50%;
  }
  #stars  { opacity: 0.7; }
  #stars2 { width: 2px; height: 2px; opacity: 0.9; }
  #stars3 { width: 2px; height: 2px; }

  #stars::after,
  #stars2::after,
  #stars3::after,
  #stars4::after {
    content: " ";
    position: fixed;
    top: 2000px;
    background: transparent;
  }

  #stars::after  { width: 1px; height: 1px; }
  #stars2::after { width: 2px; height: 2px; }
  #stars3::after { width: 3px; height: 3px; }
  #stars4::after { width: 1px; height: 1px; }

  #stars  { animation: animStar  80s linear infinite; }
  #stars2 { animation: animStar 140s linear infinite; }
  #stars3 { animation: animStar 200s linear infinite; }
  #stars4 { animation: animStar 320s linear infinite; opacity: 0.35; }

  /* Subtle CSS nebula — two overlapping radial blobs */
  #nebula {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(ellipse 60% 30% at 70% 25%, rgba(80, 40, 160, 0.20) 0%, transparent 70%),
      radial-gradient(ellipse 50% 25% at 25% 60%, rgba(20, 80, 140, 0.20) 0%, transparent 70%);
    background-color: transparent !important;
  }

  :global([data-theme="light"]) #nebula,
  :global([data-theme="light"]) #satellite {
    display: none;
  }

  #satellite {
    position: fixed;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: #fff;
    pointer-events: none;
    z-index: 0;
    animation: satellite 35s linear infinite;
    opacity: 0;
  }

  @keyframes satellite {
    0%   { transform: translate(-20px, -20px); opacity: 0; }
    5%   { opacity: 0.7; }
    95%  { opacity: 0.7; }
    100% { transform: translate(calc(100vw + 20px), calc(30vh + 20px)); opacity: 0; }
  }

  @keyframes twinkle {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.15; }
  }

  @keyframes animStar {
    from { transform: translateY(0px); }
    to   { transform: translateY(-2000px); }
  }
</style>

<script>
  const W = Math.max(window.screen.width, window.innerWidth);
  const H = 2000;

  function multipleBoxShadow(n: number, color: string, glowSize: number, glowColor: string): string {
    const star = () => {
      const x = Math.floor(Math.random() * W);
      const y = Math.floor(Math.random() * H);
      const sharp = `${x}px ${y}px 0px ${color}`;
      const glow = glowSize > 0 ? `, ${x}px ${y}px ${glowSize}px ${glowColor}` : "";
      return sharp + glow;
    };
    let value = star();
    for (let i = 2; i <= n; i++) value += `, ${star()}`;
    return value;
  }

  const shadowsSmall  = multipleBoxShadow(350, "#FFF", 0, "");
  const shadowsMedium = multipleBoxShadow(100, "#FFF", 1.5, "#FFF");
  const shadowsBig    = multipleBoxShadow(50,  "#FFF", 3, "#FFF");
  const shadowsDim    = multipleBoxShadow(250, "#ffffff55", 0, "");

  const shadowsSmallDark  = multipleBoxShadow(350, "#00000055", 0, "");
  const shadowsMediumDark = multipleBoxShadow(100, "#00000088", 3, "rgba(0,0,0,0.15)");
  const shadowsBigDark    = multipleBoxShadow(50,  "#000000aa", 6, "rgba(0,0,0,0.1)");
  const shadowsDimDark    = multipleBoxShadow(250, "#00000033", 0, "");

  const style = document.createElement("style");
  document.head.appendChild(style);

  function applyTheme(theme: string) {
    const isDark = theme !== "light";
    style.textContent = `
      #stars        { box-shadow: ${isDark ? shadowsSmall  : shadowsSmallDark}  !important; }
      #stars::after { box-shadow: ${isDark ? shadowsSmall  : shadowsSmallDark}  !important; }
      #stars2        { box-shadow: ${isDark ? shadowsMedium : shadowsMediumDark} !important; }
      #stars2::after { box-shadow: ${isDark ? shadowsMedium : shadowsMediumDark} !important; }
      #stars3        { box-shadow: ${isDark ? shadowsBig    : shadowsBigDark}    !important; }
      #stars3::after { box-shadow: ${isDark ? shadowsBig    : shadowsBigDark}    !important; }
      #stars4        { box-shadow: ${isDark ? shadowsDim    : shadowsDimDark}    !important; }
      #stars4::after { box-shadow: ${isDark ? shadowsDim    : shadowsDimDark}    !important; }
    `;
  }

  applyTheme(document.body.getAttribute("data-theme") ?? "dark");

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    requestAnimationFrame(() => {
      applyTheme(document.body.getAttribute("data-theme") ?? "dark");
    });
  });

  // --- Twinkling stars ---
  const twinkleStyle = document.createElement("style");
  document.head.appendChild(twinkleStyle);

  const TWINKLE_COUNT = 40;
  let twinkleCSS = "";
  for (let i = 0; i < TWINKLE_COUNT; i++) {
    const x = Math.floor(Math.random() * W);
    const y = Math.floor(Math.random() * H * 0.6);
    const dur = (2.5 + Math.random() * 4).toFixed(2);
    const delay = (Math.random() * 8).toFixed(2);
    twinkleCSS += `.tw-${i}{position:fixed;left:${x}px;top:${y}px;width:2px;height:2px;border-radius:50%;background:#fff;pointer-events:none;z-index:0;animation:twinkle ${dur}s ${delay}s ease-in-out infinite;}`;
  }
  twinkleStyle.textContent = twinkleCSS;

  const twinkleContainer = document.createElement("div");
  twinkleContainer.style.cssText = "position:fixed;inset:0;pointer-events:none;z-index:0;background:transparent!important;";
  for (let i = 0; i < TWINKLE_COUNT; i++) {
    const el = document.createElement("div");
    el.className = `tw-${i}`;
    twinkleContainer.appendChild(el);
  }
  document.body.appendChild(twinkleContainer);

  // --- Firefly ---
  const FIREFLY_COUNT = 2;
  for (let f = 0; f < FIREFLY_COUNT; f++) {
    const fly = document.createElement("div");
    fly.className = "firefly";
    fly.style.cssText = `
      position: fixed;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      pointer-events: none;
      z-index: 1;
      top: 0;
      left: 0;
      box-shadow: 0 0 6px 3px #b8ffb0, 0 0 2px 1px #b8ffb0;
    `;
    document.body.appendChild(fly);

    let x = Math.random() * window.innerWidth;
    let y = Math.random() * window.innerHeight * 0.7;
    let vx = (Math.random() - 0.5) * 0.6;
    let vy = (Math.random() - 0.5) * 0.6;
    let opacity = Math.random();
    let opacityDir = (Math.random() - 0.5) * 0.008;

    function updateFireflyVisibility() {
      fly.style.display = document.body.getAttribute("data-theme") === "light" ? "none" : "";
    }

    updateFireflyVisibility();
    document.getElementById("theme-toggle")?.addEventListener("click", () => {
      requestAnimationFrame(updateFireflyVisibility);
    });

    function animateFly() {
      x += vx;
      y += vy;

      // Randomly nudge direction
      if (Math.random() < 0.02) vx += (Math.random() - 0.5) * 0.4;
      if (Math.random() < 0.02) vy += (Math.random() - 0.5) * 0.4;

      // Clamp speed
      vx = Math.max(-0.8, Math.min(0.8, vx));
      vy = Math.max(-0.8, Math.min(0.8, vy));

      // Bounce off edges
      if (x < 0 || x > window.innerWidth)  vx *= -1;
      if (y < 0 || y > window.innerHeight * 0.8) vy *= -1;

      // Blink
      opacity += opacityDir;
      if (opacity >= 1 || opacity <= 0) opacityDir *= -1;
      opacity = Math.max(0, Math.min(1, opacity));

      fly.style.transform = `translate(${x}px, ${y}px)`;
      fly.style.opacity = String(opacity);

      requestAnimationFrame(animateFly);
    }

    animateFly();
  }

  // --- Scroll fade ---
  const nebula = document.getElementById("nebula");
  // Base opacities per layer — must match CSS
  const starLayers: [HTMLElement | null, number][] = [
    [document.getElementById("stars"),  0.7],
    [document.getElementById("stars2"), 0.9],
    [document.getElementById("stars3"), 1],
    [document.getElementById("stars4"), 0.35],
    [twinkleContainer,                  1],
    [nebula,                            1],
  ];

  function updateOnScroll() {
    const scrollY = window.scrollY;
    let fadeStart = 0;
    let fadeEnd = 0;

    const about = document.getElementById("about");
    if (!about) {
      const fixed = 1 - 0.7;
      starLayers.forEach(([el, base]) => { if (el) el.style.opacity = String(base * fixed); });
      return;
    }

    const aboutTop = about.getBoundingClientRect().top + window.scrollY;
    fadeStart = aboutTop - window.innerHeight;
    fadeEnd = aboutTop;

    let progress = 0;
    if (scrollY > fadeStart) {
      progress = Math.min((scrollY - fadeStart) / (fadeEnd - fadeStart), 1);
    }

    const fade = 1 - progress * 0.7;
    starLayers.forEach(([el, base]) => { if (el) el.style.opacity = String(base * fade); });
  }

  window.addEventListener("scroll", updateOnScroll, { passive: true });
  updateOnScroll();
</script>
